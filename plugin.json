{
  "spec": "soksak-plugin-spec@1",
  "id": "soksak-plugin-git-diff",
  "name": "깃 변경",
  "version": "1.0.2",
  "repo": "https://github.com/soksak-ai/soksak-plugin-git-diff.git",
  "description": "변경 파일 목록과 unified diff 를 보여주는 git 뷰. staged(index) 토글 지원.",
  "permissions": [
    "ui",
    "git:read",
    "commands",
    "terminal"
  ],
  "contributes": {
    "views": [
      {
        "id": "view",
        "title": "깃 변경",
        "icon": "±",
        "placements": [
          "sidebar-right",
          "content"
        ],
        "defaultPlacement": "sidebar-right"
      }
    ],
    "nodes": [
      {
        "id": "file",
        "description": "변경 파일 행(클릭=diff 보기). data-node=\"file/<경로>\""
      },
      {
        "id": "staged",
        "description": "staged 체크박스(토글=working↔index diff)"
      },
      {
        "id": "refresh",
        "description": "새로고침 버튼(목록·diff 재로드)"
      }
    ]
  }
}
