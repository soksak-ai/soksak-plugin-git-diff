{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-git-diff",
  "name": {
    "en": "Git Changes",
    "ko": "깃 변경"
  },
  "version": "0.0.1",
  "repo": "https://github.com/soksak-ai/soksak-plugin-git-diff.git",
  "description": {
    "en": "Git view showing changed file list and unified diff. Supports staged (index) toggle.",
    "ko": "변경 파일 목록과 unified diff 를 보여주는 git 뷰. staged(index) 토글 지원."
  },
  "permissions": [
    "ui",
    "commands",
    "terminal"
  ],
  "dependencies": {
    "soksak-plugin-git-core": "^0.1.0"
  },
  "contributes": {
    "commands": [
      {
        "name": "files",
        "title": {
          "en": "Lists changed files",
          "ko": "변경 파일 목록을 조회합니다"
        }
      },
      {
        "name": "read",
        "title": {
          "en": "Reads the unified diff",
          "ko": "unified diff 를 조회합니다"
        }
      }
    ],
    "views": [
      {
        "id": "view",
        "title": {
          "en": "Git Changes",
          "ko": "깃 변경"
        },
        "icon": "±",
        "placements": [
          "sidebar-right",
          "content"
        ],
        "defaultPlacement": "sidebar-right",
        "status": [
          "loading",
          "clean",
          "changed",
          "error"
        ]
      }
    ],
    "nodes": [
      {
        "id": "file",
        "description": "변경 파일 행(클릭=diff 보기). data-node=\"file/<경로>\""
      },
      {
        "id": "staged",
        "description": "staged 체크박스(토글=working↔index diff)"
      },
      {
        "id": "refresh",
        "description": "새로고침 버튼(목록·diff 재로드)"
      }
    ]
  }
}
